<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PDF Generator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        body {
            font-family: 'Manrope', sans-serif;
            background: linear-gradient(135deg, #f5f7fb 0%, #e8eef9 100%);
            min-height: 100vh;
        }

        .app-shell {
            max-width: 920px;
            margin: 40px auto;
            padding: 24px;
        }

        .panel {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(19, 33, 68, 0.08);
            padding: 28px;
        }

        .top-nav {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
        }

        .top-nav a {
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 999px;
            color: #16325c;
            background: #dce8ff;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <main class="app-shell">
        <div class="top-nav">
            <a asp-controller="Employee" asp-action="Index">Employee Form</a>
            <a asp-controller="Employee" asp-action="Download">Download PDF</a>
        </div>

        <section class="panel">
            @RenderBody()
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>