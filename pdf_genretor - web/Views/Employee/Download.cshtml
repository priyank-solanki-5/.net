@model EmployeePdfSelectionViewModel

@{
    ViewData["Title"] = "Download PDF";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Download Employee PDF</h1>
    <p class="text-secondary mb-0">Select an employee ID and download that employee's PDF report.</p>
</div>

@if (!Model.EmployeeOptions.Any())
{
    <div class="alert alert-warning mb-0">
        No employee data found. <a asp-action="Index" class="alert-link">Add an employee first</a>.
    </div>
}
else
{
    <form asp-action="Download" method="post" class="row g-3 align-items-end">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-8">
            <label asp-for="SelectedEmployeeId" class="form-label"></label>
            <select asp-for="SelectedEmployeeId" asp-items="Model.EmployeeOptions" class="form-select">
                <option value="">Select employee ID</option>
            </select>
            <span asp-validation-for="SelectedEmployeeId" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-success w-100">Download PDF</button>
        </div>
    </form>
}